generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum HouseholdRole {
  OWNER
  ADMIN
  MEMBER
}

enum IncomeType {
  CASH
  CARD
}

enum IncomeCategory {
  SALARY
  PART_TIME
  RENT
  SALE
  FOP
  OTHER
}

enum ExpenseSource {
  CASH
  CARD
}

enum NotificationType {
  ROOM_DELETED
}

model User {
  id              String            @id @default(cuid())
  name            String?
  email           String            @unique
  emailVerified   DateTime?
  image           String?
  passwordHash    String?
  defaultScopeKey String            @default("personal")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  accounts        Account[]
  sessions        Session[]
  memberships     HouseholdMember[]
  notifications   Notification[]
  createdExpenses Expense[]         @relation("ExpenseCreatedBy")
  createdIncomes  Income[]          @relation("IncomeCreatedBy")
  currencyIncomes CurrencyIncome[]  @relation("CurrencyIncomeCreatedBy")
  pushSubscriptions PushSubscription[]
}

model Household {
  id                String            @id @default(cuid())
  name              String
  personalOwnerId   String?           @unique
  joinCode          String?           @unique
  joinRole          HouseholdRole?
  joinCodeExpiresAt DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  members           HouseholdMember[]
  expenses          Expense[]
  incomes           Income[]
  currencyIncomes   CurrencyIncome[]
  limits            CategoryLimit[]
}

model HouseholdMember {
  id          String        @id @default(cuid())
  role        HouseholdRole @default(MEMBER)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  userId      String
  householdId String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([userId, householdId])
  @@index([householdId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  createdAt DateTime         @default(now())
  readAt    DateTime?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model Expense {
  id          String        @id @default(cuid())
  title       String
  amount      Int
  mirrorKey   String?
  category    String
  source      ExpenseSource @default(CARD)
  date        DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  householdId String
  createdById String
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy   User          @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([householdId, date])
}

model Income {
  id          String         @id @default(cuid())
  title       String
  amount      Int
  mirrorKey   String?
  type        IncomeType
  category    IncomeCategory
  date        DateTime
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  householdId String
  createdById String
  household   Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy   User           @relation("IncomeCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([householdId, date])
}


model CurrencyIncome {
  id          String    @id @default(cuid())
  title       String    @default("")
  currency    String
  amount      Float
  mirrorKey   String?
  date        DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  householdId String
  createdById String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  createdBy   User      @relation("CurrencyIncomeCreatedBy", fields: [createdById], references: [id], onDelete: Cascade)

  @@index([householdId, date])
}
model CategoryLimit {
  id          String    @id @default(cuid())
  category    String
  limitAmount Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, category])
  @@index([householdId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}


model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  authKey   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
